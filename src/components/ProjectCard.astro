---
interface Props {
    title: string;
    description: string;
    category: string;
    badge?: string;
    technologies?: string[];
    role: string;
    proof: string;
    highlights: string[];
    gradient: 'coral' | 'blue' | 'gold';
    visual: 'journal' | 'dashboard' | 'infra';
    link?: { href: string; label: string };
    external?: boolean;
    index?: number;
    variant?: 'feature' | 'row';
}

const {
    title,
    description,
    category,
    badge,
    technologies = [],
    role,
    proof,
    highlights,
    gradient,
    visual,
    link,
    external = false,
    index = 0,
    variant = 'row',
} = Astro.props;

const revealClass = index % 2 === 0 ? 'reveal-left' : 'reveal-right';
const visualClass = `project--${visual}`;
const variantClass = `project--${variant}`;
const visibleHighlights = variant === 'feature' ? highlights.slice(0, 3) : highlights.slice(0, 1);
---

<article class={`project ${visualClass} ${variantClass} ${revealClass}`}>
    <div class="project__header">
        <div class="project__meta">
            <span class="project__category">{category}</span>
        </div>
        {badge && <span class="project__badge">{badge}</span>}
    </div>

    <div class="project__content">
        <div class="project__head">
            <span class="project__mark" aria-hidden="true">{title}</span>
            <h3 class="project__title">{title}</h3>
            <p class="project__description">{description}</p>
        </div>

        <p class="project__proof">{proof}</p>

        {variant === 'feature' ? (
            <div class="project__notes">
                {visibleHighlights.map((item) => (
                    <span class="project__note">{item}</span>
                ))}
            </div>
        ) : (
            highlights[0] && <p class="project__aside">{highlights[0]}</p>
        )}

        <div class="project__footer">
            <div class="project__micro">
                <span class="project__role">{role}</span>
                <div class="project__tags">
                    {technologies.slice(0, 3).map(tech => (
                        <span class="project__tag">{tech}</span>
                    ))}
                </div>
            </div>
            {link && (
                <a
                    href={link.href}
                    class="project__link"
                    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                    {link.label}
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                        {external
                            ? <path d="M5 3h8v8M13 3L5 11"/>
                            : <path d="M3 8h10M9 4l4 4-4 4"/>
                        }
                    </svg>
                </a>
            )}
        </div>
    </div>
</article>
