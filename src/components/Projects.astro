---
import ProjectCard from './ProjectCard.astro';
import type { Locale, Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
    lang: Locale;
}

const { t, ids, lang } = Astro.props;

const projectMeta = [
    {
        technologies: ['Next.js', 'React', 'TypeScript', 'Supabase', 'Dexie', 'E2EE'],
        gradient: 'coral' as const,
        visual: 'journal' as const,
    },
    {
        technologies: ['React', 'TypeScript', 'Node.js', 'PostgreSQL'],
        gradient: 'blue' as const,
        visual: 'dashboard' as const,
    },
    {
        technologies: ['Docker', 'Docker Compose', 'Linux', 'Nginx', 'Networking'],
        gradient: 'gold' as const,
        visual: 'infra' as const,
    },
];

const projects = t.projects.items.map((item, i) => ({
    title: item.title,
    description: item.description,
    category: item.category,
    badge: item.badge,
    role: item.role,
    proof: item.proof,
    highlights: item.highlights,
    link: item.linkLabel ? {
        href: item.linkUrl || (i === 0 ? `/${lang}/projects/espejo/` : `#${ids.caseStudy}`),
        label: item.linkLabel,
    } : undefined,
    external: !!item.linkUrl,
    ...projectMeta[i],
}));

const [featuredProject, ...otherProjects] = projects;
---

<section class="section" id={ids.projects}>
    <div class="container">
        <header class="section__header reveal">
            <h2 class="section__title">{t.projects.title}</h2>
            <p class="section__subtitle">{t.projects.subtitle}</p>
        </header>

        <div class="projects-showcase reveal">
            {featuredProject && <ProjectCard {...featuredProject} index={0} variant="feature" />}
            <div class="projects-list">
                {otherProjects.map((project, i) => (
                    <ProjectCard {...project} index={i + 1} variant="row" />
                ))}
            </div>
        </div>
    </div>
</section>
