---
import type { Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
}

const { t, ids } = Astro.props;
---

<section class="section contact-section" id={ids.contact}>
    <div class="container">
        <div class="contact__panel reveal">
            <div class="contact__copy">
                <header class="section__header contact__header">
                    <h2 class="section__title">{t.contact.title}</h2>
                </header>

                <div class="contact__text">
                    <p>{t.contact.text}</p>
                </div>
            </div>

            <div class="contact__actions">
                <a href="mailto:jhuertamedina@gmail.com" class="contact__email">
                    jhuertamedina@gmail.com
                </a>
                <div class="contact__social">
                    <a href="https://linkedin.com/in/juhume" target="_blank" rel="noopener noreferrer" class="social-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                            <rect x="2" y="9" width="4" height="12"/>
                            <circle cx="4" cy="4" r="2"/>
                        </svg>
                        {t.contact.linkedin}
                    </a>
                    <a href="https://github.com/juhume" target="_blank" rel="noopener noreferrer" class="social-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                        </svg>
                        {t.contact.github}
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
