---
import type { Locale, Translations } from '../i18n';

import { getSectionIds } from '../i18n';
import type { SectionIds } from '../i18n';

interface Props {
    t: Translations;
    lang: Locale;
}

const { t, lang } = Astro.props;
const ids = getSectionIds(lang);
const email = 'jhuertamedina@gmail.com';
const projects = [
    {
        title: t.projects.items[0].title,
        desc: t.projects.items[0].description,
        href: `/${lang}/projects/espejo/`,
        icon: '/espejo-logo.jpg',
        url: 'espejo.day',
        urlHref: 'https://espejo.day',
    },
    {
        title: t.projects.items[1].title,
        desc: t.projects.items[1].description,
        href: 'https://diplotest.es',
        external: true,
        icon: null,
        url: 'diplotest.es',
    },
    {
        title: t.projects.items[2].title,
        desc: t.projects.items[2].description,
        href: `/${lang}/projects/homelab/`,
        icon: null,
        url: null,
    },
];
---

<main class="home">
    <div class="home__container">
        <header class="home__header">
            <img src="/julio-huerta.jpg" alt={t.about.photoAlt} class="home__photo" width="96" height="96" />
            <div>
                <h1 class="home__name">Julio Huerta Medina</h1>
                <p class="home__role">{t.home.role}</p>
            </div>
        </header>
        <div class="home__bio" id={ids.about}>
            {t.about.paragraphs.slice(0, 2).map(p => <p set:html={p} />)}
        </div>
        <section class="home__experience" id={ids.experience}>
            <h2 class="home__section-title">{t.experience.title}</h2>
            <div class="home__exp-company-header">
                <span class="home__exp-company">{t.experience.company}</span>
                <span class="home__exp-period">{t.experience.period}</span>
            </div>
            <div class="home__exp-timeline">
                {t.experience.entries.map((entry, i) => (
                    <div class={`home__exp-entry ${i === 0 ? 'home__exp-entry--current' : ''}`}>
                        <div class="home__exp-header">
                            <span class="home__exp-role">{entry.role}</span>
                            <span class="home__exp-period">{entry.period}</span>
                        </div>
                        <p class="home__exp-context">{entry.context}</p>
                        <div class="home__exp-stack">
                            {entry.stack.map(tech => (
                                <span class="home__tag">{tech}</span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>
        <section class="home__projects" id={ids.projects}>
            <h2 class="home__section-title">{t.projects.title}</h2>
            {projects.map(project => (
                <a
                    href={project.href}
                    class="home__project"
                    {...(project.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                    <div class="home__project-info">
                        {project.icon && <img src={project.icon} alt="" class="home__project-icon" width="32" height="32" />}
                        <div>
                            <div class="home__project-top">
                                <h3 class="home__project-name">{project.title}</h3>
                                {project.url && (
                                    <span
                                        class="home__project-url"
                                        data-href={project.urlHref || `https://${project.url}`}
                                        role="link"
                                        tabindex="0"
                                    >
                                        {project.url} ↗
                                    </span>
                                )}
                            </div>
                            <p class="home__project-desc">{project.desc}</p>
                        </div>
                    </div>
                    <span class="home__project-arrow">→</span>
                </a>
            ))}
        </section>
        <section class="home__contact" id={ids.contact}>
            <h2 class="home__section-title">{t.contact.title}</h2>
            <p class="home__contact-intro">{t.contact.text}</p>
            <a href={`mailto:${email}`} class="home__email">{email}</a>
            <div class="home__social">
                <a href="https://linkedin.com/in/juhume" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                    {t.contact.linkedin}
                </a>
                <a href="https://github.com/juhume" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                    {t.contact.github}
                </a>
            </div>
            <nav class="home__footer-nav" aria-label="Footer navigation">
                <a href={`/${lang}/blog/`}>{t.nav.blog}</a>
                <span class="home__footer-sep">·</span>
                <a href={`/${lang}/projects/espejo/`}>{t.projects.items[0].title}</a>
                <span class="home__footer-sep">·</span>
                <a href={`/${lang}/projects/homelab/`}>{t.projects.items[2].title}</a>
            </nav>
        </section>
    </div>
</main>

<script>
    document.querySelectorAll('.home__project-url[data-href]').forEach(el => {
        const open = () => window.open((el as HTMLElement).dataset.href!, '_blank');
        el.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            open();
        });
        el.addEventListener('keydown', (e) => {
            if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
                e.preventDefault();
                e.stopPropagation();
                open();
            }
        });
    });
</script>

<style>
    .home {
        padding: var(--space-xl) var(--space-md);
        padding-top: calc(var(--space-3xl) + 2rem);
        position: relative;
    }
    .home::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 80%;
        max-width: 600px;
        height: 400px;
        background: radial-gradient(ellipse, color-mix(in srgb, var(--accent) 8%, transparent), transparent 70%);
        pointer-events: none;
        z-index: -1;
    }
    .home__container { max-width: 680px; margin: 0 auto; }

    /* Scroll offset for fixed nav */
    .home__experience,
    .home__projects,
    .home__contact { scroll-margin-top: 5rem; }

    @media (max-width: 380px) {
        .home__header { flex-direction: column; align-items: flex-start; gap: var(--space-xs); }
        .home__photo { width: 64px !important; height: 64px !important; }
        .home__email { font-size: 0.85rem; overflow-wrap: break-word; word-break: normal; }
    }

    @media (max-width: 480px) {
        .home {
            padding-left: var(--space-sm);
            padding-right: var(--space-sm);
            padding-top: calc(var(--space-2xl) + 2rem);
        }
        .home__header { gap: var(--space-sm); margin-bottom: var(--space-lg); }
        .home__photo { width: 72px; height: 72px; }
        .home__name { font-size: clamp(1.35rem, 5vw, 1.8rem); overflow-wrap: break-word; }
        .home__role { font-size: 0.85rem; }
        .home__bio { margin-bottom: var(--space-lg); }
        .home__bio p:first-child { font-size: 1rem; }
        .home__exp-header { flex-direction: column; gap: 0.15rem; }
        .home__exp-entry { padding: var(--space-sm); }
        .home__email { font-size: 1rem; word-break: break-all; }
        .home__project { padding: var(--space-sm); }
        .home__project-desc { font-size: 0.8rem; }
        .home__project-arrow { font-size: 1rem; }
        .home__contact { padding-top: var(--space-md); }
        .home__experience { margin-bottom: var(--space-lg); }
        .home__projects { margin-bottom: var(--space-lg); }
    }

    @media (min-width: 768px) {
        .home__container { max-width: 920px; }
        .home__photo { width: 112px !important; height: 112px !important; }
    }

    .home__header {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        margin-bottom: var(--space-xl);
        padding-bottom: var(--space-lg);
        border-bottom: 1px solid var(--border);
    }
    .home__photo {
        width: 96px; height: 96px;
        border-radius: 30% 70% 53% 47% / 52% 35% 65% 48%;
        object-fit: cover;
        flex-shrink: 0;
        transition: border-radius 0.6s ease, box-shadow 0.6s ease;
        box-shadow: 0 0 0 2px var(--bg-primary), 0 0 0 3.5px color-mix(in srgb, var(--accent) 35%, transparent);
    }
    .home__photo:hover {
        border-radius: 58% 42% 36% 64% / 43% 68% 32% 57%;
        box-shadow: 0 0 0 2px var(--bg-primary), 0 0 0 3.5px var(--accent), 0 8px 24px var(--shadow);
    }
    .home__name {
        font-family: var(--font-display);
        font-size: clamp(1.8rem, 3.5vw, 2.6rem);
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.15;
        letter-spacing: -0.03em;
    }
    .home__role {
        font-size: 0.95rem;
        color: var(--accent-text, #2B9B6A);
        margin-top: 0.25rem;
        font-weight: 500;
    }

    /* Header entrance choreography */
    .js .home__photo {
        opacity: 0;
        animation: photoFadeIn 0.8s var(--ease-out) 0.1s forwards;
    }
    @keyframes photoFadeIn {
        to { opacity: 1; }
    }
    .js .home__role {
        opacity: 0;
        animation: roleFadeIn 0.5s var(--ease-out) 0.55s forwards;
    }
    @keyframes roleFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .home__bio { margin-bottom: var(--space-xl); }
    .home__bio p {
        font-size: 1rem;
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: var(--space-sm);
    }
    .home__bio p:first-child {
        font-size: 1.1rem;
        color: var(--text-primary);
        line-height: 1.65;
    }
    .home__bio p:last-child { margin-bottom: 0; }

    /* Section titles — accent underline */
    .home__section-title {
        font-family: var(--font-display);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-muted);
        margin-bottom: var(--space-md);
        padding-bottom: 0.4rem;
        border-bottom: 2.5px solid var(--accent, #83DEB5);
        display: inline-block;
    }

    /* Experience section */
    .home__experience { margin-bottom: var(--space-xl); }
    .home__subtitle {
        font-size: 1rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: var(--space-md);
    }
    .home__exp-company-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-sm);
        flex-wrap: wrap;
        margin-bottom: var(--space-md);
    }
    .home__exp-company {
        font-family: var(--font-display);
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
    }
    .home__exp-timeline {
        position: relative;
        padding-left: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .home__exp-timeline::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--border);
        border-radius: 2px;
    }
    .home__exp-entry {
        position: relative;
        padding: var(--space-md);
        background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
        border: 1px solid var(--border);
        border-radius: 12px;
    }
    .home__exp-entry::before {
        content: '';
        position: absolute;
        left: calc(-1.25rem - 3px);
        top: 1.35rem;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--text-muted);
        border: 2px solid var(--bg-primary);
    }
    .home__exp-entry--current::before {
        background: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-subtle);
    }
    .home__exp-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-sm);
        flex-wrap: wrap;
        margin-bottom: 0.25rem;
    }
    .home__exp-period {
        font-size: 0.8rem;
        color: var(--text-muted);
        font-family: var(--font-display);
        letter-spacing: 0.02em;
    }
    .home__exp-role {
        font-size: 0.95rem;
        color: var(--accent-text, #2B9B6A);
        font-weight: 600;
    }
    .home__exp-context {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-top: 0.35rem;
        margin-bottom: 0.75rem;
    }
    .home__exp-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }
    .home__tag {
        font-size: 0.65rem;
        font-family: var(--font-display);
        padding: 0.2rem 0.55rem;
        border-radius: 4px;
        background: var(--accent-subtle, rgba(43, 155, 106, 0.08));
        color: var(--accent-text, #2B9B6A);
        letter-spacing: 0.03em;
        font-weight: 600;
    }
    .home__tag:nth-child(3n+2) {
        background: color-mix(in srgb, var(--sage) 15%, var(--bg-primary));
        color: var(--sage);
    }
    .home__tag:nth-child(3n) {
        background: color-mix(in srgb, var(--gold) 15%, var(--bg-primary));
        color: var(--gold);
    }

    /* Projects — card style */
    .home__projects {
        margin-bottom: var(--space-xl);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .home__project {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-md);
        border: 1px solid var(--border);
        border-radius: 12px;
        background: color-mix(in srgb, var(--bg-secondary) 50%, transparent);
        text-decoration: none;
        color: inherit;
        transition: border-color var(--duration-fast) var(--ease-out),
                    background var(--duration-fast) var(--ease-out),
                    box-shadow var(--duration-normal) var(--ease-out);
    }
    .home__project:hover {
        border-color: color-mix(in srgb, var(--accent) 40%, transparent);
        background: var(--bg-secondary);
        box-shadow: 0 8px 32px var(--shadow);
    }
    .home__project:hover .home__project-name { color: var(--accent-text, #2B9B6A); }
    .home__project:hover .home__project-arrow { transform: translateX(6px); color: var(--accent-text, #2B9B6A); }
    .home__project-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .home__project-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
        border: 1px solid var(--border);
        background: var(--bg-primary);
    }
    .home__project-top {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .home__project-name {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.4;
        transition: color var(--duration-fast) var(--ease-out);
    }
    .home__project-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin-top: 0.125rem;
        line-height: 1.5;
    }
    .home__project-url {
        font-size: 0.7rem;
        color: var(--accent-text, #2B9B6A);
        font-family: var(--font-display);
        letter-spacing: 0.02em;
        cursor: pointer;
        transition: opacity var(--duration-fast) var(--ease-out);
    }
    .home__project-url:hover {
        opacity: 0.7;
    }
    .home__project-url:focus-visible {
        outline: 2px solid var(--accent-text, #2B9B6A);
        outline-offset: 2px;
        border-radius: 2px;
    }
    .home__project-arrow {
        font-size: 1.25rem;
        color: var(--text-muted);
        transition: transform var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
        flex-shrink: 0;
        margin-left: var(--space-sm);
    }

    /* Contact */
    .home__contact {
        margin-bottom: var(--space-lg);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--border);
    }
    .home__contact-intro {
        font-size: 1.05rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: var(--space-sm);
    }
    .home__email {
        display: inline-block;
        font-family: var(--font-display);
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 700;
        color: var(--accent-text, #2B9B6A);
        text-decoration: none;
        margin-bottom: var(--space-md);
        letter-spacing: -0.01em;
        background-image: linear-gradient(var(--accent), var(--accent));
        background-size: 0% 2px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        transition: color var(--duration-fast) var(--ease-out), background-size 0.3s var(--ease-out);
    }
    .home__email:hover { color: var(--accent-hover); background-size: 100% 2px; }
    .home__social { display: flex; gap: 0.5rem; margin-bottom: var(--space-md); }
    .home__social a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-decoration: none;
        padding: 0.4rem 0.75rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--bg-secondary) 50%, transparent);
        transition: color var(--duration-fast) var(--ease-out),
                    border-color var(--duration-fast) var(--ease-out),
                    background var(--duration-fast) var(--ease-out);
    }
    .home__social a:hover {
        color: var(--accent-text, #2B9B6A);
        border-color: color-mix(in srgb, var(--accent) 30%, transparent);
        background: var(--bg-secondary);
    }
    .home__social svg {
        width: 15px;
        height: 15px;
        flex-shrink: 0;
    }

    /* Footer nav */
    .home__footer-nav {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding-top: var(--space-sm);
        border-top: 1px solid var(--border);
    }
    .home__footer-nav a {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--duration-fast) var(--ease-out);
    }
    .home__footer-nav a:hover {
        color: var(--accent-text, #2B9B6A);
    }
    .home__footer-sep {
        font-size: 0.8rem;
        color: var(--text-muted);
        opacity: 0.4;
    }
</style>
