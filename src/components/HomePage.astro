---
import type { Locale, Translations } from '../i18n';

interface Props {
    t: Translations;
    lang: Locale;
}

const { t, lang } = Astro.props;
---

<main class="card">
    <div class="card__glow" aria-hidden="true"></div>

    <div class="card__inner">
        <div class="card__photo-ring">
            <img
                src="/julio-huerta.jpg"
                alt={t.about.photoAlt}
                class="card__photo"
                width="160"
                height="160"
            />
        </div>

        <h1 class="card__name home__name">JULIO HUERTA MEDINA</h1>
        <p class="card__role">{t.home.role}</p>

        <div class="card__bio">
            <p>{t.home.bio}</p>
        </div>

        <a href={`/cv/julio-huerta-cv-${lang === 'en' ? 'en' : 'es'}.pdf`} class="card__cv" download>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t.home.cvDownload}
        </a>
    </div>
</main>

<style>
    /* ==========================================
       Card Container
       ========================================== */
    .card {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: var(--space-lg) var(--space-md);
    }

    .card__inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        max-width: 560px;
        gap: 0;
        z-index: 1;
    }

    /* ==========================================
       Ambient Glow
       ========================================== */
    .card__glow {
        position: absolute;
        top: var(--glow-y, 50%);
        left: var(--glow-x, 50%);
        transform: translate(-50%, -55%);
        width: 550px;
        height: 550px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--accent) 8%, transparent) 0%,
            color-mix(in srgb, var(--gold) 4%, transparent) 40%,
            transparent 70%
        );
        pointer-events: none;
        z-index: 0;
        filter: blur(40px);
        will-change: transform;
    }

    :global([data-theme="dark"]) .card__glow {
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--accent) 12%, transparent) 0%,
            color-mix(in srgb, var(--accent) 5%, transparent) 40%,
            transparent 70%
        );
    }

    /* ==========================================
       Photo with gradient ring
       ========================================== */
    .card__photo-ring {
        position: relative;
        padding: 3px;
        border-radius: 30% 70% 53% 47% / 52% 35% 65% 48%;
        background: linear-gradient(135deg, var(--accent), var(--gold), var(--accent));
        margin-bottom: var(--space-lg);
        transition: border-radius 0.6s ease, box-shadow 0.6s ease;
        box-shadow: 0 8px 32px color-mix(in srgb, var(--accent) 15%, transparent);
    }

    .card__photo-ring:hover {
        border-radius: 58% 42% 36% 64% / 43% 68% 32% 57%;
        box-shadow: 0 12px 40px color-mix(in srgb, var(--accent) 25%, transparent);
    }

    .card__photo {
        width: 140px;
        height: 140px;
        border-radius: inherit;
        object-fit: cover;
        display: block;
        border: 3px solid var(--bg-primary);
        flex-shrink: 0;
    }

    :global(.js) .card__photo-ring {
        opacity: 0;
        animation: springScale 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s forwards;
    }

    /* ==========================================
       Name
       ========================================== */
    .card__name {
        font-family: 'Vila Morena', var(--font-display);
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: normal;
        color: var(--text-primary);
        line-height: 1.15;
        letter-spacing: 0.02em;
        margin-bottom: 0.35rem;
        overflow-wrap: normal;
        word-break: keep-all;
    }

    :global(.js) .card__name {
        opacity: 0;
        animation: springIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.35s forwards;
    }

    /* ==========================================
       Role
       ========================================== */
    .card__role {
        font-size: var(--text-base);
        color: var(--accent-text);
        font-weight: 500;
        margin-bottom: var(--space-sm);
    }

    :global(.js) .card__role {
        opacity: 0;
        animation: springIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s forwards;
    }

    /* ==========================================
       Proof Badges
       ========================================== */
    .card__proofs {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-xs);
        margin-bottom: var(--space-lg);
    }

    .card__proof {
        font-size: 0.72rem;
        font-weight: 500;
        padding: 0.3rem 0.75rem;
        border-radius: 100px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
        color: var(--text-secondary);
        letter-spacing: 0.02em;
        white-space: nowrap;
    }

    :global(.js) .card__proofs {
        opacity: 0;
        animation: springIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.65s forwards;
    }

    /* ==========================================
       Live Homelab Badge
       ========================================== */
    .card__live {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: var(--space-md);
        font-size: 0.7rem;
        font-weight: 500;
        color: var(--accent-text);
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .card__live-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent-text);
        box-shadow: 0 0 6px var(--accent);
        animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
        0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--accent); }
        50% { opacity: 0.5; box-shadow: 0 0 12px var(--accent); }
    }

    :global(.js) .card__live {
        opacity: 0;
        animation: springIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.75s forwards;
    }

    /* ==========================================
       Bio
       ========================================== */
    .card__bio {
        margin-bottom: var(--space-sm);
    }

    .card__bio p {
        font-size: var(--text-base);
        color: var(--text-secondary);
        line-height: 1.75;
        max-width: 48ch;
        margin: 0 auto var(--space-xs);
    }

    .card__bio p:last-child {
        margin-bottom: 0;
    }

    :global(.js) .card__bio {
        opacity: 0;
        animation: springIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.85s forwards;
    }

    /* Bio Shimmer Effect */
    @keyframes textShimmer {
        0% { background-position: -100% 0; }
        100% { background-position: 200% 0; }
    }

    .card__bio--shimmer p {
        background: linear-gradient(
            90deg,
            var(--text-secondary) 0%,
            var(--text-secondary) 40%,
            var(--accent-text) 50%,
            var(--text-secondary) 60%,
            var(--text-secondary) 100%
        );
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: textShimmer 1.5s ease-in-out 1.6s forwards;
    }

/* ==========================================
       CV Download Link
       ========================================== */
    .card__cv {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.5rem 1rem;
        border: 1px solid var(--border);
        border-radius: 100px;
        transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
    }
    .card__cv:hover {
        color: var(--accent-text);
        border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    }
    :global(.js) .card__cv {
        opacity: 0;
        animation: springIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.05s forwards;
    }

    /* ==========================================
       Animations
       ========================================== */
    @keyframes springIn {
        0% { opacity: 0; transform: translateY(20px) scale(0.97); }
        60% { opacity: 1; transform: translateY(-3px) scale(1.01); }
        80% { transform: translateY(1px) scale(0.995); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes springScale {
        0% { opacity: 0; transform: scale(0.8); }
        60% { opacity: 1; transform: scale(1.05); }
        80% { transform: scale(0.98); }
        100% { opacity: 1; transform: scale(1); }
    }

    /* ==========================================
       Responsive
       ========================================== */
    @media (max-width: 480px) {
        .card {
            padding: var(--space-md) var(--space-sm);
        }

        .card__glow {
            width: 320px;
            height: 320px;
        }

        .card__photo-ring {
            margin-bottom: var(--space-md);
        }

        .card__photo {
            width: 110px;
            height: 110px;
        }

        .card__name {
            font-size: clamp(1.6rem, 6vw, 2.2rem);
        }

        .card__role {
            font-size: 0.85rem;
        }

        .card__proofs {
            margin-bottom: var(--space-md);
        }

        .card__proof {
            font-size: 0.65rem;
            padding: 0.25rem 0.6rem;
        }

        .card__bio p {
            font-size: 0.875rem;
        }

        .card__tagline {
            font-size: 0.8rem;
            margin-bottom: var(--space-lg);
        }

    }

    @media (min-width: 768px) {
        .card__photo {
            width: 170px;
            height: 170px;
        }

        .card__photo-ring {
            padding: 3.5px;
        }

    }
</style>

<script is:inline>
// Check for reduced motion preference
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
if (prefersReducedMotion) {
    // Skip all JS animations if user prefers reduced motion
} else {
    
    // 1. CURSOR-REACTIVE GLOW
    (() => {
        const card = document.querySelector('.card');
        const glow = document.querySelector('.card__glow');
        
        if (!card || !glow) return;
        
        let currentX = 50;
        let currentY = 50;
        let targetX = 50;
        let targetY = 50;
        
        // Linear interpolation for smooth movement
        function lerp(start, end, factor) {
            return start + (end - start) * factor;
        }
        
        function updateGlow() {
            currentX = lerp(currentX, targetX, 0.1);
            currentY = lerp(currentY, targetY, 0.1);
            
            card.style.setProperty('--glow-x', currentX + '%');
            card.style.setProperty('--glow-y', currentY + '%');
            
            requestAnimationFrame(updateGlow);
        }
        
        // Mouse tracking
        card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            targetX = ((e.clientX - rect.left) / rect.width) * 100;
            targetY = ((e.clientY - rect.top) / rect.height) * 100;
        });
        
        // Reset when mouse leaves
        card.addEventListener('mouseleave', () => {
            targetX = 50;
            targetY = 50;
        });
        
        // Mobile: gyroscope effect
        if (window.DeviceOrientationEvent) {
            window.addEventListener('deviceorientation', (e) => {
                if (e.gamma !== null && e.beta !== null) {
                    // Subtle movement based on device tilt
                    targetX = 50 + (e.gamma * 0.5); // Left/right tilt
                    targetY = 50 + (e.beta * 0.3);  // Forward/back tilt
                    
                    // Clamp values
                    targetX = Math.max(20, Math.min(80, targetX));
                    targetY = Math.max(20, Math.min(80, targetY));
                }
            });
        }
        
        // Start animation loop
        updateGlow();
    })();

    // 2. BIO TEXT SHIMMER
    (() => {
        // Add shimmer effect after entrance animation
        setTimeout(() => {
            document.querySelector('.card__bio')?.classList.add('card__bio--shimmer');
        }, 1600);
        
        // Reset to normal text after shimmer
        setTimeout(() => {
            const bio = document.querySelector('.card__bio');
            if (bio) {
                bio.classList.remove('card__bio--shimmer');
                bio.querySelectorAll('p').forEach(p => {
                    p.style.background = 'none';
                    p.style.webkitTextFillColor = '';
                });
            }
        }, 3200);
    })();

}
</script>
