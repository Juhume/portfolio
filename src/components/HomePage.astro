---
import type { Locale, Translations } from '../i18n';

interface Props {
    t: Translations;
    lang: Locale;
}

const { t, lang } = Astro.props;

const aboutLabel: Record<string, string> = {
    es: 'Sobre mí',
    en: 'About me',
    gl: 'Sobre min',
};

const sentidinoLabel: Record<string, string> = {
    es: 'Software con sentidiño.',
    en: 'Software con sentidiño.',
    gl: 'Software con sentidiño.',
};
---

<main class="card">
    <div class="card__inner">
        <img
            src="/julio-huerta.jpg"
            alt={t.about.photoAlt}
            class="card__photo"
            width="120"
            height="120"
        />

        <h1 class="card__name home__name">Julio Huerta Medina</h1>
        <p class="card__role">{t.home.role}</p>

        <div class="card__bio">
            <p>{t.about.paragraphs[0]}</p>
            <p>{t.about.paragraphs[1]} {sentidinoLabel[lang]}</p>
        </div>

        <nav class="card__links" aria-label="Main navigation">
            <a href={`/${lang}/projects/`} class="card__link">{t.nav.projects}</a>
            <a href={`/${lang}/blog/`} class="card__link">{t.nav.blog}</a>
            <a href={`/${lang}/#about`} class="card__link">{aboutLabel[lang]}</a>
        </nav>
    </div>
</main>

<style>
    .card {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: var(--space-lg) var(--space-md);
    }

    .card__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        max-width: 560px;
        gap: 0;
    }

    /* Photo — blob shape with hover morph */
    .card__photo {
        width: 120px;
        height: 120px;
        border-radius: 30% 70% 53% 47% / 52% 35% 65% 48%;
        object-fit: cover;
        flex-shrink: 0;
        margin-bottom: var(--space-lg);
        transition: border-radius 0.6s ease, box-shadow 0.6s ease;
        box-shadow:
            0 0 0 2px var(--bg-primary),
            0 0 0 3.5px color-mix(in srgb, var(--accent) 35%, transparent);
    }
    .card__photo:hover {
        border-radius: 58% 42% 36% 64% / 43% 68% 32% 57%;
        box-shadow:
            0 0 0 2px var(--bg-primary),
            0 0 0 3.5px var(--accent),
            0 8px 24px var(--shadow);
    }

    /* Entrance animation for photo */
    :global(.js) .card__photo {
        opacity: 0;
        animation: photoFadeIn 0.8s var(--ease-out) 0.1s forwards;
    }
    @keyframes photoFadeIn {
        to { opacity: 1; }
    }

    /* Name — Gallaecia font, char-reveal animation picks up .home__name */
    .card__name {
        font-family: 'Gallaecia', var(--font-display);
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: normal;
        color: var(--text-primary);
        line-height: 1.15;
        letter-spacing: 0.02em;
        margin-bottom: 0.35rem;
        overflow-wrap: normal;
        word-break: keep-all;
    }

    /* Role */
    .card__role {
        font-size: 0.95rem;
        color: var(--accent-text, #2B9B6A);
        font-weight: 500;
        margin-bottom: var(--space-lg);
    }
    :global(.js) .card__role {
        opacity: 0;
        animation: roleFadeIn 0.5s var(--ease-out) 0.55s forwards;
    }
    @keyframes roleFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Bio quotes */
    .card__bio {
        margin-bottom: var(--space-xl);
    }
    .card__bio p {
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.7;
        font-style: italic;
        max-width: 48ch;
        margin: 0 auto var(--space-xs);
    }
    .card__bio p:last-child {
        margin-bottom: 0;
    }

    /* 3 links in a row */
    .card__links {
        display: flex;
        align-items: center;
        gap: var(--space-lg);
    }
    .card__link {
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--accent-text, #2B9B6A);
        text-decoration: none;
        letter-spacing: 0.01em;
        position: relative;
        transition: opacity var(--duration-fast) var(--ease-out);
    }
    .card__link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1.5px;
        background: var(--accent);
        transition: width 0.3s var(--ease-out);
    }
    .card__link:hover::after {
        width: 100%;
    }
    .card__link:hover {
        opacity: 0.85;
    }

    /* Responsive */
    @media (max-width: 480px) {
        .card {
            padding: var(--space-md) var(--space-sm);
        }
        .card__photo {
            width: 96px;
            height: 96px;
            margin-bottom: var(--space-md);
        }
        .card__name {
            font-size: clamp(1.6rem, 6vw, 2.2rem);
        }
        .card__role {
            font-size: 0.85rem;
            margin-bottom: var(--space-md);
        }
        .card__bio p {
            font-size: 0.875rem;
        }
        .card__links {
            gap: var(--space-md);
        }
        .card__link {
            font-size: 0.85rem;
        }
    }

    @media (min-width: 768px) {
        .card__photo {
            width: 140px;
            height: 140px;
        }
    }
</style>
