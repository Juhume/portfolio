---
import type { Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
}

const { t, ids } = Astro.props;
---

<section class="section" id={ids.about}>
    <div class="container">
        <header class="section__header reveal">
            <span class="section__number">{t.about.sectionNumber}</span>
            <h2 class="section__title">{t.about.title}</h2>
        </header>

        <div class="about__grid">
            <div class="about__text reveal">
                {t.about.paragraphs.map(p => (
                    <p set:html={p} />
                ))}
            </div>
            <div class="about__aside reveal">
                <div class="about__principles">
                    <h4 class="about__principles-title">{t.about.principlesTitle}</h4>
                    <ul class="about__principles-list">
                        {t.about.principles.map(p => (
                            <li>{p}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
