---
import type { Locale, Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
    lang: Locale;
}

const { t, ids, lang } = Astro.props;
---

<section class="hero">
    <div class="hero__bg">
        <div class="hero__gradient-bg"></div>
    </div>

    <div class="container hero__content">
        <div class="hero__frame">
            <div class="hero__main">
                <span class="hero__label">{t.hero.label}</span>
                <h1 class="hero__title">
                    {t.hero.title}
                </h1>
                <p class="hero__subtitle">
                    {t.hero.subtitle}
                </p>
                <p class="hero__proofs-inline">
                    {t.hero.proofs.map((proof, i) => (
                        <>{i > 0 && <span class="hero__proof-sep" aria-hidden="true">·</span>}{proof}</>
                    ))}
                </p>
                <div class="hero__cta">
                    <a href={`#${ids.contact}`} class="btn btn--primary">
                        {t.hero.ctaPrimary}
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 8h10M9 4l4 4-4 4"/>
                        </svg>
                    </a>
                    <a href={`#${ids.projects}`} class="btn btn--secondary">{t.hero.ctaSecondary}</a>
                </div>
            </div>

            <div class="hero__aside">
                <div class="hero__photo">
                    <img src="/julio-huerta.jpg" alt={t.about.photoAlt} width="320" height="320" />
                </div>
            </div>
        </div>
    </div>
</section>
