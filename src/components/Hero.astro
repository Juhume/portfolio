---
import type { Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
}

const { t, ids } = Astro.props;
---

<section class="hero">
    <div class="hero__bg">
        <div class="hero__gradient-bg"></div>
    </div>

    <div class="container hero__content">
        <span class="hero__label">{t.hero.label}</span>
        <h1 class="hero__title">
            {t.hero.title}
        </h1>
        <p class="hero__subtitle">
            {t.hero.subtitle}
        </p>
        <div class="hero__cta">
            <a href={`#${ids.experience}`} class="btn btn--primary">
                {t.hero.ctaPrimary}
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 8h10M9 4l4 4-4 4"/>
                </svg>
            </a>
            <a href={`#${ids.projects}`} class="btn btn--secondary">{t.hero.ctaSecondary}</a>
        </div>
    </div>

    <div class="hero__scroll">
        <div class="hero__scroll-line"></div>
        <span>{t.hero.scroll}</span>
    </div>
</section>
