---
import type { Locale, Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
    lang: Locale;
    variant?: 'summary' | 'full';
}

const { t, ids, lang, variant = 'summary' } = Astro.props;
const blocks = variant === 'full' ? t.caseStudy.blocks : [];
---

<section class:list={['section', 'case-study', { 'case-study--page': variant === 'full' }]} id={variant === 'summary' ? ids.caseStudy : undefined}>
    <div class="container">
        {variant === 'summary' ? (
            <a href={`/${lang}/projects/espejo/`} class="case-study-teaser reveal">
                <div class="case-study-teaser__copy">
                    <span class="case-study-teaser__eyebrow">{t.caseStudy.pageEyebrow}</span>
                    <h2 class="case-study-teaser__title">{t.caseStudy.title}</h2>
                    <p class="case-study-teaser__text">{t.caseStudy.intro}</p>
                </div>
                <div class="case-study-teaser__meta">
                    <div class="case-study-teaser__chips">
                        {t.caseStudy.pageHighlights.slice(0, 3).map((item) => (
                            <span class="case-study-teaser__chip">{item}</span>
                        ))}
                    </div>
                    <span class="case-study-teaser__link">
                        {t.caseStudy.cta}
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 8h10M9 4l4 4-4 4"/>
                        </svg>
                    </span>
                </div>
            </a>
        ) : (
            <header class="case-study-page__hero">
                <span class="case-study-page__eyebrow">{t.caseStudy.pageEyebrow}</span>
                <h1 class="case-study-page__title">{t.caseStudy.title}</h1>
                <p class="case-study-page__summary">{t.caseStudy.pageSummary}</p>
                <div class="case-study-page__highlights">
                    {t.caseStudy.pageHighlights.map((item) => (
                        <span class="case-study-page__highlight">{item}</span>
                    ))}
                </div>
            </header>
        )}

        {variant === 'full' && (
            <div class="case-blocks">
                {blocks.map(block => (
                    <div class="case-block">
                        <div class="case-block__label">{block.label}</div>
                        <div class="case-block__content">
                            {block.highlight && <p class="case-block__highlight">{block.highlight}</p>}
                            {block.content && <p>{block.content}</p>}
                            {block.list && (
                                <ul class="case-block__list">
                                    {block.list.map(item => <li>{item}</li>)}
                                </ul>
                            )}
                            {block.stack && (
                                <div class="stack-tags">
                                    {block.stack.map(tag => <span class="stack-tag">{tag}</span>)}
                                </div>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        )}
    </div>
</section>
