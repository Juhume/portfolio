---
import type { Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
}

const { t, ids } = Astro.props;
---

<section class="section case-study" id={ids.caseStudy}>
    <div class="container">
        <header class="section__header reveal">
            <span class="section__number">{t.caseStudy.sectionNumber}</span>
            <h2 class="section__title">{t.caseStudy.title}</h2>
        </header>

        <div class="case-blocks">
            {t.caseStudy.blocks.map(block => (
                <div class="case-block reveal">
                    <div class="case-block__label">{block.label}</div>
                    <div class="case-block__content">
                        {block.highlight && <p class="case-block__highlight">{block.highlight}</p>}
                        {block.content && <p>{block.content}</p>}
                        {block.list && (
                            <ul class="case-block__list">
                                {block.list.map(item => <li>{item}</li>)}
                            </ul>
                        )}
                        {block.stack && (
                            <div class="stack-tags">
                                {block.stack.map(tag => <span class="stack-tag">{tag}</span>)}
                            </div>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
