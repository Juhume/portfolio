---
import type { Translations, SectionIds } from '../i18n';

interface Props {
    t: Translations;
    ids: SectionIds;
}

const { t, ids } = Astro.props;
---

<section class="section experience" id={ids.experience}>
    <div class="container">
        <div class="experience__layout">
            <header class="section__header experience__intro reveal">
                <h2 class="section__title">{t.experience.title}</h2>
                <p class="section__subtitle">{t.experience.context}</p>
            </header>

            <div class="experience__item reveal">
                <div class="experience__header">
                    <div class="experience__company">
                        <h3 class="experience__company-name">{t.experience.company}</h3>
                        <span class="experience__period">{t.experience.period}</span>
                    </div>
                    <span class="experience__role">{t.experience.role}</span>
                </div>

                <div class="experience__body">
                    <div class="experience__signals">
                        <h4 class="experience__signals-title">{t.experience.signalsTitle}</h4>
                        <div class="experience__signals-grid">
                            {t.experience.signals.map(signal => (
                                <p class="experience__signal">{signal}</p>
                            ))}
                        </div>
                    </div>

                    <div class="experience__achievements">
                        <h4 class="experience__achievements-title">{t.experience.achievementsTitle}</h4>
                        <ul class="experience__list">
                            {t.experience.achievements.map(item => (
                                <li>{item}</li>
                            ))}
                        </ul>
                    </div>

                    <div class="experience__stack">
                        {t.experience.stack.slice(0, 4).map(tag => (
                            <span class="experience__stack-tag">{tag}</span>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
