---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import Footer from '../../../../components/Footer.astro';
import { locales, getTranslations, getSectionIds } from '../../../../i18n';
import type { Locale } from '../../../../i18n';

export function getStaticPaths() {
    return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const ids = getSectionIds(lang);
const canonicalPath = `/${lang}/projects/pichurri-fitness/`;

const content = {
    es: {
        eyebrow: 'Caso de estudio',
        title: 'Pichurri Fitness',
        nameNote: '"Pichurri" es como llamo a mi cluster de agentes de IA. Viene de una forma coloquial y cariñosa de referirse a alguien en español.',
        summary: 'Un agente de IA que funciona como coach personal real: programa, recuerda, insiste, analiza y se adapta. No es un chatbot — es un sistema.',
        highlights: ['Coach 24/7 vía Telegram', '20+ cron jobs automáticos', 'Memoria persistente', 'Tracking de progresión'],
        metaTitle: 'Pichurri Fitness | Caso de estudio | Julio Huerta',
        metaDesc: 'Coach de IA autónomo construido sobre OpenClaw: entrenamiento, nutrición, running y accountability.',
        blocks: [
            { label: 'Qué es', highlight: 'Un coach de IA que no espera a que le escribas.', content: 'Pichurri Fitness es un agente autónomo que funciona 24/7 a través de Telegram. Diseña entrenamientos, controla nutrición, gestiona suplementación y mantiene un sistema de accountability. Forma parte de un ecosistema multi-agente con 5 agentes especializados (desarrollo, trading, media, fitness, coordinación), cada uno con su dominio exclusivo.' },
            { label: 'Arquitectura', highlight: 'OpenClaw + Claude + Telegram + memoria persistente.', content: '', list: ['Plataforma multi-agente OpenClaw corriendo en NAS 24/7', 'Modelo base: Claude (Anthropic) para razonamiento y análisis', 'Canal: Telegram bidireccional en tiempo real', '20+ cron jobs programados (nutrición, entreno, suplementos, hidratación, check-ins)', 'Sistema de heartbeat que detecta silencios y escribe proactivamente', 'Capacidad de delegar tareas a otros agentes del ecosistema'] },
            { label: 'Memoria', highlight: 'Cada sesión construye sobre la anterior.', content: '', list: ['Archivos diarios con ejercicios, pesos, series, nutrición y métricas', 'Memoria a largo plazo con objetivos, patrones y decisiones', 'Búsqueda semántica en todo el historial antes de responder', 'Tracking de progresión por ejercicio con historial completo', 'Detección de patrones (ejercicios que se saltan, adherencia que cambia)'] },
            { label: 'Coaching en tiempo real', highlight: 'Entrenas y reportas. El agente responde al momento.', content: 'Durante el entrenamiento, envío resultados conforme termino ejercicios. El agente sugiere pesos basándose en el historial, registra los datos reales, y si un equipo está ocupado, reordena la sesión o sugiere alternativas. Los cambios de ejercicios se fundamentan en investigación actualizada.' },
            { label: 'Running', highlight: 'Le mando pantallazos y él se encarga.', content: 'Después de cada carrera, le envío capturas del Apple Watch por Telegram. El agente extrae los datos (distancia, ritmo, frecuencia cardíaca, splits) y los compara con sesiones anteriores para ver si hay progresión real.' },
            { label: 'Accountability', highlight: 'El modo "Sin Piedad" 💀', content: 'Cada noche, check-in completo: comidas, entreno, suplementos, agua, reflexión. El agente detecta patrones y no acepta excusas vagas. Si digo "intentaré ir", responde "No intentaré. Mañana Upper A."' },
            { label: 'Resultado', highlight: 'Me está ayudando a progresar de forma consistente.', content: 'La combinación de cron jobs proactivos, memoria persistente, análisis de datos en tiempo real y un tono de coaching directo crea una experiencia que va más allá de un chatbot fitness. La estructura diaria y el seguimiento constante hacen que sea mucho más fácil mantener la disciplina.' },
            { label: 'Stack', content: '', stack: ['OpenClaw', 'Claude', 'Telegram', 'Node.js', 'Cron', 'Apple Watch'] },
        ],
    },
    en: {
        eyebrow: 'Case study',
        title: 'Pichurri Fitness',
        nameNote: '"Pichurri" is what I call my AI agent cluster. It comes from a colloquial, affectionate Spanish word — something like calling someone "little one" or "buddy", but warmer and harder to translate. Think of it as a pet name for software that knows too much about you.',
        summary: 'An AI agent that works as a real personal coach: programs, remembers, insists, analyzes and adapts. Not a chatbot — a system.',
        highlights: ['24/7 coach via Telegram', '20+ automated cron jobs', 'Persistent memory', 'Progression tracking'],
        metaTitle: 'Pichurri Fitness | Case Study | Julio Huerta',
        metaDesc: 'Autonomous AI coach built on OpenClaw: training, nutrition, running and accountability.',
        blocks: [
            { label: 'What it is', highlight: 'An AI coach that doesn\'t wait for you to write.', content: 'Pichurri Fitness is an autonomous agent running 24/7 via Telegram. It designs workouts, tracks nutrition, manages supplementation and maintains an accountability system. Part of a multi-agent ecosystem with 5 specialized agents (dev, trading, media, fitness, coordination), each with an exclusive domain.' },
            { label: 'Architecture', highlight: 'OpenClaw + Claude + Telegram + persistent memory.', content: '', list: ['Multi-agent platform OpenClaw running on NAS 24/7', 'Base model: Claude (Anthropic) for reasoning and analysis', 'Channel: real-time bidirectional Telegram', '20+ scheduled cron jobs (nutrition, training, supplements, hydration, check-ins)', 'Heartbeat system that detects silence and writes proactively', 'Ability to delegate tasks to other agents in the ecosystem'] },
            { label: 'Memory', highlight: 'Every session builds on the previous one.', content: '', list: ['Daily files with exercises, weights, sets, nutrition and metrics', 'Long-term memory with goals, patterns and decisions', 'Semantic search across all history before responding', 'Per-exercise progression tracking with full history', 'Pattern detection (skipped exercises, changing adherence)'] },
            { label: 'Real-time coaching', highlight: 'You train and report. The agent responds instantly.', content: 'During training, I send results as I finish exercises. The agent suggests weights based on history, records actual data, and if equipment is busy, reorders the session or suggests alternatives. Exercise changes are backed by current research.' },
            { label: 'Running', highlight: 'I send screenshots and it takes care of the rest.', content: 'After each run, I send Apple Watch screenshots via Telegram. The agent extracts the data (distance, pace, heart rate, splits) and compares with previous sessions to see if there\'s real progression.' },
            { label: 'Accountability', highlight: '"No Mercy" mode 💀', content: 'Every night, full check-in: meals, training, supplements, water, reflection. The agent detects patterns and doesn\'t accept vague excuses. If I say "I\'ll try to go", it responds "No trying. Tomorrow Upper A."' },
            { label: 'Result', highlight: 'It\'s helping me progress consistently.', content: 'The combination of proactive cron jobs, persistent memory, real-time data analysis and a direct coaching tone creates an experience that goes beyond a fitness chatbot. The daily structure and constant tracking make it much easier to stay disciplined.' },
            { label: 'Stack', content: '', stack: ['OpenClaw', 'Claude', 'Telegram', 'Node.js', 'Cron', 'Apple Watch'] },
        ],
    },
    gl: {
        eyebrow: 'Caso de estudo',
        title: 'Pichurri Fitness',
        nameNote: '"Pichurri" é como chamo ao meu cluster de axentes de IA. Vén dunha forma coloquial e cariñosa de referirse a alguén en español.',
        summary: 'Un axente de IA que funciona como coach persoal real: programa, lembra, insiste, analiza e adáptase. Non é un chatbot — é un sistema.',
        highlights: ['Coach 24/7 vía Telegram', '20+ cron jobs automáticos', 'Memoria persistente', 'Tracking de progresión'],
        metaTitle: 'Pichurri Fitness | Caso de estudo | Julio Huerta',
        metaDesc: 'Coach de IA autónomo construído sobre OpenClaw: adestramento, nutrición, running e accountability.',
        blocks: [
            { label: 'Que é', highlight: 'Un coach de IA que non espera a que lle escribas.', content: 'Pichurri Fitness é un axente autónomo que funciona 24/7 a través de Telegram. Deseña adestramentos, controla nutrición, xestiona suplementación e mantén un sistema de accountability. Forma parte dun ecosistema multi-axente con 5 axentes especializados (desenvolvemento, trading, media, fitness, coordinación), cada un co seu dominio exclusivo.' },
            { label: 'Arquitectura', highlight: 'OpenClaw + Claude + Telegram + memoria persistente.', content: '', list: ['Plataforma multi-axente OpenClaw correndo en NAS 24/7', 'Modelo base: Claude (Anthropic) para razoamento e análise', 'Canal: Telegram bidireccional en tempo real', '20+ cron jobs programados (nutrición, adestramento, suplementos, hidratación, check-ins)', 'Sistema de heartbeat que detecta silencios e escribe proactivamente', 'Capacidade de delegar tarefas a outros axentes do ecosistema'] },
            { label: 'Memoria', highlight: 'Cada sesión constrúe sobre a anterior.', content: '', list: ['Ficheiros diarios con exercicios, pesos, series, nutrición e métricas', 'Memoria a longo prazo con obxectivos, patróns e decisións', 'Busca semántica en todo o historial antes de responder', 'Tracking de progresión por exercicio con historial completo', 'Detección de patróns (exercicios que se saltan, adherencia que cambia)'] },
            { label: 'Coaching en tempo real', highlight: 'Adestras e reportas. O axente responde ao momento.', content: 'Durante o adestramento, envío resultados conforme remato exercicios. O axente suxire pesos baseándose no historial, rexistra os datos reais, e se un equipo está ocupado, reordena a sesión ou suxire alternativas.' },
            { label: 'Running', highlight: 'Mándolle pantallazos e el encárgase.', content: 'Despois de cada carreira, envíolle capturas do Apple Watch por Telegram. O axente extrae os datos (distancia, ritmo, frecuencia cardíaca, splits) e compáraos con sesións anteriores para ver se hai progresión real.' },
            { label: 'Accountability', highlight: 'O modo "Sen Piedade" 💀', content: 'Cada noite, check-in completo: comidas, adestramento, suplementos, auga, reflexión. O axente detecta patróns e non acepta escusas vagas.' },
            { label: 'Resultado', highlight: 'Está axudándome a progresar de forma consistente.', content: 'A combinación de cron jobs proactivos, memoria persistente, análise de datos en tempo real e un ton de coaching directo crea unha experiencia que vai máis alá dun chatbot fitness.' },
            { label: 'Stack', content: '', stack: ['OpenClaw', 'Claude', 'Telegram', 'Node.js', 'Cron', 'Apple Watch'] },
        ],
    },
};

const c = content[lang] || content.es;
---

<BaseLayout
    lang={lang}
    t={t}
    title={c.metaTitle}
    description={c.metaDesc}
    canonicalPath={canonicalPath}
>
    <Header lang={lang} t={t} ids={ids} currentPath={Astro.url.pathname} />

    <div class="case-study-page-shell">
        <div class="container">
            <a href={`/${lang}/projects/`} class="case-study-page__back">← {lang === 'en' ? 'Back to projects' : 'Volver a proyectos'}</a>
            <Breadcrumb items={[
                { label: t.nav.home || (lang === 'en' ? 'Home' : 'Inicio'), href: `/${lang}/` },
                { label: t.nav.projects, href: `/${lang}/projects/` },
                { label: 'Pichurri Fitness' }
            ]} />
        </div>

        <section class="section case-study case-study--page">
            <div class="container">
                <header class="case-study-page__hero">

                    <span class="case-study-page__eyebrow">{c.eyebrow}</span>
                    <h1 class="case-study-page__title">{c.title}</h1>
                    <p class="case-study-page__name-note">{c.nameNote}</p>
                    <p class="case-study-page__summary">{c.summary}</p>
                    <div class="case-study-page__highlights">
                        {c.highlights.map((item) => (
                            <span class="case-study-page__highlight">{item}</span>
                        ))}
                    </div>
                </header>

                <div class="case-blocks">
                    {c.blocks.map(block => (
                        <div class="case-block">
                            <div class="case-block__label">{block.label}</div>
                            <div class="case-block__content">
                                {block.highlight && <p class="case-block__highlight">{block.highlight}</p>}
                                {block.content && <p>{block.content}</p>}
                                {block.list && (
                                    <ul class="case-block__list">
                                        {block.list.map(item => <li>{item}</li>)}
                                    </ul>
                                )}
                                {block.stack && (
                                    <div class="stack-tags">
                                        {block.stack.map(tag => <span class="stack-tag">{tag}</span>)}
                                    </div>
                                )}
                            </div>
                        </div>
                    ))}
                </div>

                <aside class="pf-cross-nav">
                    <span class="pf-cross-nav__label">{lang === 'en' ? 'Also see' : lang === 'gl' ? 'Tamén podes ver' : 'También puedes ver'}</span>
                    <div class="pf-cross-nav__links">
                        <a href={`/${lang}/projects/homelab/`} class="pf-cross-nav__link">
                            Homelab →
                        </a>
                        <a href={`/${lang}/projects/espejo/`} class="pf-cross-nav__link">
                            Espejo →
                        </a>
                    </div>
                </aside>
            </div>
        </section>
    </div>

    <Footer t={t} />
</BaseLayout>

<style>
    .case-study-page__emoji {
        font-size: 3rem;
        display: block;
        margin-bottom: 0.5rem;
    }

    .case-study-page__name-note {
        font-size: 0.8125rem;
        color: var(--text-muted, #888);
        font-style: italic;
        margin-top: 0.5rem;
        margin-bottom: 1rem;
        max-width: 32rem;
        line-height: 1.5;
    }

    .pf-cross-nav {
        margin-top: var(--space-2xl, 3rem);
        padding-top: var(--space-lg, 1.5rem);
        border-top: 1px solid var(--border, #333);
    }

    .pf-cross-nav__label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent, #83DEB5);
        display: block;
        margin-bottom: 0.75rem;
    }

    .pf-cross-nav__links {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .pf-cross-nav__link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border: 1px solid var(--border, #333);
        border-radius: 0.75rem;
        background: var(--bg-secondary);
        color: var(--text-primary);
        text-decoration: none;
        font-weight: 500;
        transition: border-color 0.2s, background 0.2s;
        width: fit-content;
    }

    .pf-cross-nav__link:hover {
        border-color: var(--accent, #83DEB5);
        background: var(--bg-primary);
    }

    @media (min-width: 640px) {
        .pf-cross-nav__links {
            flex-direction: row;
        }
    }
</style>
