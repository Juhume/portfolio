---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import CaseStudy from '../../../../components/CaseStudy.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import Footer from '../../../../components/Footer.astro';
import { locales, getTranslations, getSectionIds } from '../../../../i18n';
import type { Locale } from '../../../../i18n';

export function getStaticPaths() {
    return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const ids = getSectionIds(lang);
const canonicalPath = `/${lang}/projects/espejo/`;
const structuredData = {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: t.caseStudy.pageMetaTitle,
    description: t.caseStudy.pageMetaDescription,
    url: `https://juliohuerta.dev${canonicalPath}`,
    inLanguage: lang,
    about: {
        '@type': 'SoftwareApplication',
        name: 'Espejo',
        applicationCategory: 'LifestyleApplication',
    },
    author: {
        '@type': 'Person',
        name: 'Julio Huerta',
    },
};
---

<BaseLayout
    lang={lang}
    t={t}
    title={t.caseStudy.pageMetaTitle}
    description={t.caseStudy.pageMetaDescription}
    canonicalPath={canonicalPath}
    structuredData={structuredData}
>
    <Header lang={lang} t={t} ids={ids} currentPath={Astro.url.pathname} />

    <div class="case-study-page-shell">
        <div class="container">
            <a href={`/${lang}/projects/`} class="case-study-page__back">← {t.caseStudy.backToProjects}</a>
            <Breadcrumb items={[
                { label: lang === 'en' ? 'Home' : lang === 'es' ? 'Inicio' : 'Inicio', href: `/${lang}/` },
                { label: t.nav.projects, href: `/${lang}/projects/` },
                { label: 'Espejo' }
            ]} />
        </div>
        <CaseStudy t={t} ids={ids} lang={lang} variant="full" />
    </div>

    <Footer t={t} />
</BaseLayout>
