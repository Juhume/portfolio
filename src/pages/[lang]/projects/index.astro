---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverFlow from '../../../components/CoverFlow';
import { locales, getTranslations, getSectionIds } from '../../../i18n';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
    return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const ids = getSectionIds(lang);
const canonicalPath = `/${lang}/projects/`;

const ctaLabels: Record<string, string> = {
    es: 'Ver caso de estudio →',
    en: 'View case study →',
    gl: 'Ver caso de estudo →',
};

// Map projects to CoverFlow props
const projectLinks: string[] = [
    `/${lang}/projects/espejo/`,
    'https://diplotest.es',
    `/${lang}/projects/homelab/`,
];

const projectStacks: string[][] = [
    ['Next.js', 'React', 'TypeScript', 'Supabase', 'IndexedDB'],
    ['Next.js', 'Supabase', 'Auth', 'Analytics'],
    ['Docker', 'Compose', 'Home Assistant', 'AI Agents'],
];

const projects = t.projects.items.map((item, i) => ({
    title: item.title,
    description: item.description,
    stack: projectStacks[i],
    url: projectLinks[i],
    badge: item.badge,
    category: item.category,
}));
---

<BaseLayout
    lang={lang}
    t={t}
    title={`${t.projects.title} | Julio Huerta`}
    description={t.projects.subtitle}
    canonicalPath={canonicalPath}
>
    <Header lang={lang} t={t} ids={ids} currentPath={Astro.url.pathname} />

    <main class="projects-page">
        <div class="projects-page__inner">
            <CoverFlow
                client:load
                projects={projects}
                ctaLabel={ctaLabels[lang]}
            />
        </div>
    </main>

    <Footer t={t} />
</BaseLayout>

<style>
    .projects-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: calc(4rem + var(--space-xl, 2rem)) var(--space-md, 1rem) var(--space-xl, 2rem);
        overflow-x: hidden;
    }

    .projects-page__inner {
        width: 100%;
        max-width: 960px;
        margin: 0 auto;
    }

    @media (max-width: 480px) {
        .projects-page {
            padding-left: var(--space-sm, 0.5rem);
            padding-right: var(--space-sm, 0.5rem);
        }
    }
</style>
