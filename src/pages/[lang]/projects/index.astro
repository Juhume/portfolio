---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CoverFlow from '../../../components/CoverFlow';
import { locales, getTranslations, getSectionIds } from '../../../i18n';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
    return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const ids = getSectionIds(lang);
const canonicalPath = `/${lang}/projects/`;

const projectLinks: string[] = [
    `/${lang}/projects/espejo/`,
    'https://diplo-test.vercel.app/',
    'https://github.com/Juhume/HeyHaiku',
    `/${lang}/projects/homelab/`,
];

const projectStacks: string[][] = [
    ['Next.js', 'React', 'TypeScript', 'Supabase', 'IndexedDB'],
    ['Next.js', 'Supabase', 'Auth', 'Analytics'],
    ['Next.js 15', 'TypeScript', 'Turso', 'Drizzle', 'Better Auth'],
    ['Docker', 'Compose', 'Home Assistant', 'AI Agents'],
];

const projectThemes = [
    { gradient: 'linear-gradient(145deg, #fce4dc 0%, #f5c4b5 50%, #f0a890 100%)', gradientDark: 'linear-gradient(145deg, #2d1a16 0%, #3a211c 50%, #452820 100%)', accent: '#c4553a', accentDark: '#e8866e', textColor: '#3d1510', textColorDark: '#ecd0c8', image: '/espejo-icon.png' },
    { gradient: 'linear-gradient(145deg, #dce8fc 0%, #b8d0f5 50%, #95b8ee 100%)', gradientDark: 'linear-gradient(145deg, #141e32 0%, #1a2840 50%, #20304d 100%)', accent: '#3a62a8', accentDark: '#7ba4e8', textColor: '#112040', textColorDark: '#c8d8f0', image: '/diplotest-icon.png' },
    { gradient: 'linear-gradient(145deg, #ecdcf0 0%, #d8bee0 50%, #c4a0d0 100%)', gradientDark: 'linear-gradient(145deg, #221828 0%, #2c2036 50%, #362844 100%)', accent: '#6e3a82', accentDark: '#b88acc', textColor: '#28102e', textColorDark: '#d8c4e0', icon: '🖊️' },
    { gradient: 'linear-gradient(145deg, #d4f0e2 0%, #b0e0c8 50%, #88cfae 100%)', gradientDark: 'linear-gradient(145deg, #101e18 0%, #162820 50%, #1c3228 100%)', accent: '#1e7a4d', accentDark: '#5cc890', textColor: '#0a2618', textColorDark: '#c0e8d0', icon: '⚡' },
];

const projects = t.projects.items.map((item, i) => ({
    title: item.title,
    description: item.description,
    stack: projectStacks[i],
    url: projectLinks[i],
    badge: item.badge,
    category: item.category,
    ctaLabel: item.linkLabel + (projectLinks[i].startsWith('http') ? ' ↗' : ' →'),
    external: projectLinks[i].startsWith('http'),
    ...projectThemes[i],
}));
---

<BaseLayout
    lang={lang}
    t={t}
    title={`${t.projects.title} | juhume`}
    description={t.projects.subtitle}
    canonicalPath={canonicalPath}
>
    <Header lang={lang} t={t} ids={ids} currentPath={Astro.url.pathname} />

    <main class="projects-page">
        <div class="container">
            <Breadcrumb items={[
                { label: t.nav.home || (lang === 'en' ? 'Home' : 'Inicio'), href: `/${lang}/` },
                { label: t.nav.projects }
            ]} />
        </div>
        <header class="projects-page__header">
            <h1 class="projects-page__title">{t.projects.title}</h1>
        </header>
        <div class="projects-page__inner">
            <CoverFlow
                client:load
                projects={projects}
            />
        </div>
    </main>

    <Footer t={t} />
</BaseLayout>

<style>
    .projects-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: calc(3.5rem + 1rem) var(--space-md, 1rem) 1rem;
        overflow-x: hidden;
    }

    .projects-page__header {
        text-align: center;
        margin-bottom: 0.4rem;
    }

    .projects-page__title {
        font-family: var(--font-display);
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.03em;
    }

    .projects-page__inner {
        width: 100%;
        max-width: 960px;
        margin: 0 auto;
    }

    @media (max-width: 480px) {
        .projects-page {
            padding-left: var(--space-sm, 0.5rem);
            padding-right: var(--space-sm, 0.5rem);
        }
        .projects-page__header {
            margin-bottom: 0.5rem;
        }
    }
</style>
