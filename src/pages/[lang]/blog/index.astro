---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Footer from '../../../components/Footer.astro';
import { locales, getTranslations, getSectionIds } from '../../../i18n';
import type { Locale } from '../../../i18n';
import { getCollection } from 'astro:content';
import { groupPostsBySlug, resolvePost, getReadTime } from '../../../utils/blog';

export function getStaticPaths() {
    return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = getTranslations(lang);
const ids = getSectionIds(lang);
const allPosts = await getCollection('blog');
const postsBySlug = groupPostsBySlug(allPosts);

const posts = [...postsBySlug.values()]
    .map(slugPosts => resolvePost(slugPosts, lang))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const hasTranslations = posts.some(p => p.data.lang === lang);
---

<BaseLayout
    lang={lang}
    t={t}
    title={`${t.blog.title} | Julio Huerta`}
    description={hasTranslations || lang === 'es' ? t.blog.subtitle : t.blog.spanishOnlyText}
    canonicalPath={`/${lang}/blog/`}
    noindex={!hasTranslations && lang !== 'es'}
>
    <Header lang={lang} t={t} ids={ids} currentPath={Astro.url.pathname} />

    <section class="blog">
        <div class="container">
            <Breadcrumb items={[
                { label: lang === 'en' ? 'Home' : lang === 'es' ? 'Inicio' : 'Inicio', href: `/${lang}/` },
                { label: t.nav.blog }
            ]} />
            <header class="blog__header">
                <h1 class="blog__title">{t.blog.title}</h1>
                <p class="blog__subtitle">{hasTranslations || lang === 'es' ? t.blog.subtitle : t.blog.spanishOnlyTitle}</p>
            </header>

            <div class="blog__toggle" role="tablist">
                <button class="blog__toggle-btn blog__toggle-btn--active" role="tab" aria-selected="true" data-filter="all">
                    {lang === 'es' ? 'Todo' : lang === 'en' ? 'All' : 'Todo'}
                </button>
                <button class="blog__toggle-btn" role="tab" aria-selected="false" data-filter="profesional">
                    {lang === 'es' ? 'Profesional' : lang === 'en' ? 'Professional' : 'Profesional'}
                </button>
                <button class="blog__toggle-btn" role="tab" aria-selected="false" data-filter="personal">
                    {lang === 'es' ? 'Personal' : lang === 'en' ? 'Personal' : 'Persoal'}
                </button>
            </div>

            {!hasTranslations && lang !== 'es' ? (
                <div class="blog-locale-note">
                    <p class="blog-locale-note__text">{t.blog.spanishOnlyText}</p>
                    <a href="/es/blog/" class="btn btn--primary">{t.blog.readInSpanish}</a>
                </div>
            ) : posts.length === 0 ? (
                <p class="blog__empty">{t.blog.noPosts}</p>
            ) : (
                <div class="blog__list">
                    {posts.map(post => {
                        const readTime = getReadTime(post.body);
                        return (
                            <a href={`/${lang}/blog/${post.data.canonicalSlug || post.id}/`} class="blog-card" data-category={post.data.category || 'profesional'}>
                                <time class="blog-card__date" datetime={post.data.date.toISOString()}>
                                    {post.data.date.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
                                </time>
                                <h2 class="blog-card__title">{post.data.title}</h2>
                                <p class="blog-card__description">{post.data.description}</p>
                                <div class="blog-card__meta">
                                    <span>{readTime} {t.blog.minRead}</span>
                                    {post.data.tags && (
                                        <div class="blog-card__tags">
                                            {post.data.tags.map(tag => (
                                                <span class="blog-card__tag" data-tag={tag}>{tag}</span>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            </a>
                        );
                    })}
                </div>
            )}

            <a href={`/${lang}/`} class="blog__back">← {t.blog.backToHome}</a>
        </div>
    </section>

    <Footer t={t} />

    <style>
        .blog__toggle {
            display: flex;
            gap: 0;
            margin-bottom: var(--space-xl);
            background: var(--bg-secondary);
            border-radius: 999px;
            padding: 4px;
            width: fit-content;
        }
        .blog__toggle-btn {
            padding: 0.5rem 1.25rem;
            border: none;
            border-radius: 999px;
            background: transparent;
            color: var(--text-muted);
            font-family: var(--font-body);
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: all var(--duration-fast) var(--ease-out);
        }
        .blog__toggle-btn--active {
            background: var(--accent);
            color: var(--bg-primary);
            font-weight: 600;
        }
        .blog__toggle-btn:hover:not(.blog__toggle-btn--active) {
            color: var(--text-primary);
        }
        .blog-card[data-category] { transition: opacity var(--duration-fast) var(--ease-out); }
        .blog-card.hidden { display: none; }
    </style>

    <script>
        function initBlogToggle() {
            const buttons = document.querySelectorAll('.blog__toggle-btn');
            const cards = document.querySelectorAll('.blog-card[data-category]');
            if (!buttons.length) return;

            buttons.forEach(btn => {
                const fresh = btn.cloneNode(true) as HTMLElement;
                btn.replaceWith(fresh);
                fresh.addEventListener('click', () => {
                    const filter = fresh.dataset.filter;
                    document.querySelectorAll('.blog__toggle-btn').forEach(b => {
                        b.classList.remove('blog__toggle-btn--active');
                        b.setAttribute('aria-selected', 'false');
                    });
                    fresh.classList.add('blog__toggle-btn--active');
                    fresh.setAttribute('aria-selected', 'true');

                    cards.forEach(card => {
                        const cat = (card as HTMLElement).dataset.category;
                        if (filter === 'all' || cat === filter) {
                            card.classList.remove('hidden');
                        } else {
                            card.classList.add('hidden');
                        }
                    });
                });
            });
        }

        // Works on first load AND after View Transitions
        initBlogToggle();
        document.addEventListener('astro:page-load', initBlogToggle);
    </script>
</BaseLayout>
