---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Julio Huerta | Desarrollador Web · Frontend / Full-Stack',
    description = 'Aplicaciones web modernas con React, Next.js, TypeScript, Node.js y Docker. Codigo claro, sistemas robustos.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
        rel="stylesheet"
    />
</head>
<body>
    <!-- Grain Overlay -->
    <div class="grain"></div>

    <!-- Custom Cursor -->
    <div class="cursor"></div>

    <slot />

    <script>
        import '../scripts/theme';
        import '../scripts/navigation';
        import '../scripts/animations';
    </script>
</body>
</html>
