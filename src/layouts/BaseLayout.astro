---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Julio Huerta | Desarrollador Web · Frontend / Full-Stack',
    description = 'Aplicaciones web modernas con React, Next.js, TypeScript, Node.js y Docker. Codigo claro, sistemas robustos.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Julio Huerta" />
    <meta name="keywords" content="desarrollador web, frontend, full-stack, React, Next.js, TypeScript, Node.js, Docker" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Julio Huerta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Julio Huerta",
        "url": "https://juliohuerta.dev",
        "jobTitle": "Desarrollador Web Full-Stack",
        "knowsAbout": ["React", "Next.js", "TypeScript", "Node.js", "Docker"],
        "sameAs": [
            "https://linkedin.com/in/juhume",
            "https://github.com/juhume"
        ]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
        rel="stylesheet"
    />
</head>
<body>
    <!-- Skip to content -->
    <a href="#main-content" class="skip-to-content">Saltar al contenido</a>

    <!-- Scroll Progress -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <!-- Grain Overlay -->
    <div class="grain" aria-hidden="true"></div>

    <!-- Custom Cursor -->
    <div class="cursor" aria-hidden="true"></div>

    <main id="main-content">
        <slot />
    </main>

    <script>
        import '../scripts/theme';
        import '../scripts/navigation';
        import '../scripts/animations';
    </script>
</body>
</html>
