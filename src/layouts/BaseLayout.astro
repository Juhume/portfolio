---
import '../styles/global.css';
import type { Locale, Translations } from '../i18n';
import { locales } from '../i18n';

interface Props {
    lang: Locale;
    t: Translations;
}

const { lang, t } = Astro.props;
const canonicalURL = new URL(`/${lang}/`, 'https://juliohuerta.dev');
---

<!DOCTYPE html>
<html lang={lang} data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <meta name="author" content="Julio Huerta" />
    <meta name="keywords" content={t.meta.keywords} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang alternates -->
    {locales.map(loc => (
        <link rel="alternate" hreflang={loc} href={`https://juliohuerta.dev/${loc}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://juliohuerta.dev/es/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:locale" content={t.meta.ogLocale} />
    <meta property="og:site_name" content="Julio Huerta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Julio Huerta",
        "url": "https://juliohuerta.dev",
        "jobTitle": t.meta.jobTitle,
        "worksFor": {
            "@type": "Organization",
            "name": "BBVA"
        },
        "knowsAbout": ["Web Components", "Lit", "TypeScript", "React", "Next.js", "Node.js", "Docker"],
        "sameAs": [
            "https://linkedin.com/in/juhume",
            "https://github.com/juhume"
        ]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
        rel="stylesheet"
    />
</head>
<body>
    <!-- Skip to content -->
    <a href="#main-content" class="skip-to-content">{t.a11y.skipToContent}</a>

    <!-- Scroll Progress -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <main id="main-content">
        <slot />
    </main>

    <script>
        import '../scripts/theme';
        import '../scripts/navigation';
        import '../scripts/animations';
    </script>
</body>
</html>
